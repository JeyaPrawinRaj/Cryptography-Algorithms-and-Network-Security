# ================= BASIC TEST RULES =================

alert icmp any any -> any any (msg:"ICMP TEST"; sid:9000001; rev:1;)
alert tcp any any -> any 80 (msg:"HTTP DETECTED"; sid:9000002; rev:1;)

# ================= SCAN DETECTION =================

alert tcp any any -> $HOME_NET any (msg:"SYN Scan"; flags:S,12; sid:9000020; rev:1;)
alert udp any any -> $HOME_NET any (msg:"UDP Scan"; sid:9000021; rev:1;)
alert icmp any any -> $HOME_NET any (msg:"PING Sweep"; itype:8; sid:9000022; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"FIN Scan"; flags:F,12; sid:9000023; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"NULL Scan"; flags:0; sid:9000024; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"XMAS Scan"; flags:FPU,12; sid:9000025; rev:1;)

# ================= GOOGLE PING =================

alert icmp any any -> 8.8.8.8 any (msg:"PING to Google"; itype:8; sid:9000031; rev:1;)
alert icmp 8.8.8.8 any -> any any (msg:"PING Reply from Google"; itype:0; sid:9000032; rev:1;)

# ================= HTTP ATTACKS =================

alert tcp any any -> any 80 (msg:"SQL Injection"; content:"SELECT"; http_uri; sid:9000060; rev:1;)
alert tcp any any -> any 80 (msg:"XSS Attack"; content:"<script>"; http_uri; sid:9000061; rev:1;)
alert tcp any any -> any 80 (msg:"Directory Traversal"; content:"../"; http_uri; sid:9000062; rev:1;)

# ================= DNS =================

alert udp any any -> any 53 (msg:"DNS Query"; sid:9000070; rev:1;)
alert udp any any -> any 53 (msg:"Suspicious DNS"; content:"malware"; sid:9000071; rev:1;)
